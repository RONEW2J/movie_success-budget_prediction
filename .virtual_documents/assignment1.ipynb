


import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns





df = pd.read_csv('data/adult.csv')


df.shape


df.info()
# Getting info about data columns


#  Which features are numerical and which are categorical?
df.select_dtypes(include=[np.number])


df.select_dtypes(exclude=[np.number])


# Are there missing values in the dataset? Which columns and how many?
df.isna().sum()


# But we know that we have '?' values
df[df == '?'] = np.nan
df.isna().sum()


# What is the distribution of age across the population?
plt.figure(figsize=(8,4))
sns.histplot(df['age'].dropna(), bins=30, kde=True)
plt.title("Age distribution")
plt.xlabel("Age")
plt.ylabel("Count")
plt.show()


# How are weekly working hours distributed?
plt.figure(figsize=(8,4))
sns.histplot(df['hours.per.week'].dropna(), bins=24, kde=False)
plt.title("Hours-per-week distribution")
plt.xlabel("Hours per week")
plt.ylabel("Count")
plt.show()


df['hours.per.week'].describe()


# What is the distribution of the target variables (<=50k vs >50k)?
sns.countplot(data = df , x = df['income'])


# What are the mean and median values of numerical features for each income group?
num_df = df.select_dtypes(include=[np.number])
means = num_df.mean()
medians = num_df.median()

stats = pd.DataFrame({
    'mean': means,
    'median': medians,
})

print(stats)


# How many individuals belong to the >50K class vs <=50K class (absolute and percentage)?
counts = df['income'].value_counts()
percent = df['income'].value_counts(normalize=True)*100
pd.DataFrame({'count':counts, 'percent': percent})


# Is the dataset balanced or imbalanced?
df['income'].value_counts(normalize=True)


# What percentage of people with >50K income corresponds to each education level?
plt.figure(figsize=(12, 8))
education_income = pd.crosstab(df['education'], df['income'], normalize='index') * 100
education_income.plot(kind='bar', stacked=True)
plt.title('Percentage distribution of income by education')
plt.ylabel('Percentage (%)')
plt.xticks(rotation=45)
plt.show()


# How does income distribution vary by gender?'
plt.figure(figsize=(10, 6))
sns.countplot(data=df, x='income', hue='sex')
plt.title('Distribution of income by sex')
plt.show()


# How does income vary by workclass?
wc = pd.crosstab(df['workclass'], df['income'], normalize='index') * 100
wc_sorted = wc.sort_values('>50K', ascending=False)
wc_sorted.head(15)
plt.figure(figsize=(10,6))
wc_sorted['>50K'].plot(kind='bar')
plt.ylabel('% >50K')
plt.title('Percent >50K by workclass')
plt.show()


# How is income distributed across different occupations?
occ = pd.crosstab(df['occupation'], df['income'], normalize='index')*100
occ_sorted = occ.sort_values('>50K', ascending=False)
occ_sorted.head(20)
plt.figure(figsize=(12,6))
occ_sorted['>50K'].plot(kind='bar')
plt.ylabel('% >50K')
plt.title('Percent >50K by occupation')
plt.show()


# What percentage of people earn >50K in different native countries?
country = pd.crosstab(df['native.country'], df['income'], normalize='index')*100
country_sorted = country.sort_values('>50K', ascending=False)
counts = df['native.country'].value_counts()
valid_countries = counts[counts>50].index
country.loc[valid_countries].sort_values('>50K', ascending=False).head(20)

plt.figure(figsize=(12,6))
country.loc[valid_countries]['>50K'].sort_values(ascending=False).head(20).plot(kind='bar')
plt.ylabel('% >50K')
plt.title('Top countries (>50 rows) by % earning >50K')
plt.show()


# Which numerical features are strongly correlated with each other?
num_df_corr = df.select_dtypes(include=[np.number])
corr = num_df_corr.corr()
plt.figure(figsize=(10,6))
sns.heatmap(num_df_corr, annot=True, cmap='YlGnBu')
plt.title('Correlation Heatmap')
plt.show()
corr


# Are there outliers in age or working hours?
plt.figure(figsize=(10,4))
plt.subplot(1,2,1)
sns.boxplot(x='age', data=df)
plt.title('Age boxplot')
plt.subplot(1,2,2)
sns.boxplot(x='hours.per.week', data=df)
plt.title('Hours-per-week boxplot')
plt.show()
# show extreme values
df[df['age']>df['age'].quantile(0.99)][['age','income']].head()
df[df['hours.per.week']>df['hours.per.week'].quantile(0.99)][['hours.per.week','income']].head()


# What is the distribution of capital-gain and capital-loss, and are there extreme values?
for col in ['capital.gain','capital.loss']:
    print(df[col].value_counts().head())
    nz = df[df[col] > 0][col]
    if len(nz)>0:
        plt.figure(figsize=(6,3))
        sns.histplot(np.log1p(nz), bins=40, kde=True)
        plt.title(f'Log(1 + {col}) distribution for non-zero values')
        plt.show()
    else:
        print(f"No non-zero values for {col}")



